{
  "name": "todo-sdd",
  "version": "2.0.0",
  "description": "Aplicação To-Do com Spec Driven Development (SDD)",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/presentation/server.js",
    "dev": "tsx watch src/presentation/server.ts",
    "dev:test": "cross-env NODE_ENV=test ALLOW_TEST_RESET=1 tsx src/presentation/server.ts",
    "dev:vite": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "start-server-and-test dev:test http://127.0.0.1:3000 cypress:run",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run"
  },
  "dependencies": {
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.10",
    "@vitest/coverage-v8": "^3.0.8",
    "cross-env": "^7.0.3",
    "cypress": "^14.2.0",
    "start-server-and-test": "^2.0.11",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^6.4.3",
    "vitest": "^3.0.8"
  }
}
